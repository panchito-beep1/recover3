        function Tab:CreateColorPicker(text, defaultColor, callback)
            defaultColor = defaultColor or Color3.fromRGB(1, 1, 1)
            local r, g, b = defaultColor.R * 255, defaultColor.G * 255, defaultColor.B * 255
            local open = false

            local PickerBtn = Instance.new("TextButton", Page)
            PickerBtn.BackgroundColor3 = Colors.ElementBg
            PickerBtn.Size = UDim2.new(1, 0, 0, 38)
            PickerBtn.Text = ""
            PickerBtn.AutoButtonColor = false
            Instance.new("UICorner", PickerBtn).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", PickerBtn).Color = Colors.Stroke

            local Label = Instance.new("TextLabel", PickerBtn)
            Label.BackgroundTransparency = 1
            Label.Position = UDim2.new(0, 15, 0, 0)
            Label.Size = UDim2.new(1, -60, 0, 38)
            Label.Font = Enum.Font.GothamSemibold
            Label.Text = text
            Label.TextColor3 = Colors.Text
            Label.TextSize = 14
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local ColorPreview = Instance.new("Frame", PickerBtn)
            ColorPreview.BackgroundColor3 = defaultColor
            ColorPreview.Position = UDim2.new(1, -40, 0.5, -10)
            ColorPreview.Size = UDim2.new(0, 25, 0, 20)
            Instance.new("UICorner", ColorPreview).CornerRadius = UDim.new(0, 4)
            Instance.new("UIStroke", ColorPreview).Color = Colors.Stroke

            local Container = Instance.new("Frame", PickerBtn)
            Container.BackgroundColor3 = Colors.ElementBg
            Container.Position = UDim2.new(0, 0, 0, 42)
            Container.Size = UDim2.new(1, 0, 0, 0)
            Container.ClipsDescendants = true
            Instance.new("UICorner", Container).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", Container).Color = Colors.Stroke

            local function createColorSlider(yPos, colorName, barColor, startVal)
                local SLabel = Instance.new("TextLabel", Container)
                SLabel.BackgroundTransparency = 1
                SLabel.Position = UDim2.new(0, 15, 0, yPos)
                SLabel.Size = UDim2.new(0, 15, 0, 20)
                SLabel.Font = Enum.Font.GothamBold
                SLabel.Text = colorName
                SLabel.TextColor3 = barColor
                SLabel.TextSize = 12

                local Track = Instance.new("Frame", Container)
                Track.BackgroundColor3 = Colors.TabOff
                Track.Position = UDim2.new(0, 40, 0, yPos + 7)
                Track.Size = UDim2.new(1, -55, 0, 6)
                Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

                local Fill = Instance.new("Frame", Track)
                Fill.BackgroundColor3 = barColor
                Fill.Size = UDim2.new(startVal / 255, 0, 1, 0)
                Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

                local dragging = false
                local function update(input)
                    local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    TweenService:Create(Fill, Tweens.Fast, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
                    return math.floor(pos * 255)
                end

                Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        local val = update(input)
                        if colorName == "R" then r = val elseif colorName == "G" then g = val else b = val end
                        ColorPreview.BackgroundColor3 = Color3.fromRGB(r, g, b)
                        pcall(callback, Color3.fromRGB(r, g, b))
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        local val = update(input)
                        if colorName == "R" then r = val elseif colorName == "G" then g = val else b = val end
                        ColorPreview.BackgroundColor3 = Color3.fromRGB(r, g, b)
                        pcall(callback, Color3.fromRGB(r, g, b))
                    end
                end)
            end

            createColorSlider(10, "R", Color3.fromRGB(255, 60, 60), r)
            createColorSlider(40, "G", Color3.fromRGB(60, 255, 60), g)
            createColorSlider(70, "B", Color3.fromRGB(60, 60, 255), b)

            PickerBtn.MouseButton1Click:Connect(function()
                open = not open
                TweenService:Create(Container, Tweens.Medium, {Size = UDim2.new(1, 0, 0, open and 100 or 0)}):Play()
                TweenService:Create(PickerBtn, Tweens.Medium, {Size = UDim2.new(1, 0, 0, open and 148 or 38)}):Play()
            end)
        end

        return Tab
    end

    return Window
end

return Library
