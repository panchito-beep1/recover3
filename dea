local Library = {}

-- Services
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

-- Modern Color Palette
local Colors = {
    Background = Color3.fromRGB(20, 20, 20),
    Topbar = Color3.fromRGB(25, 25, 25),
    TabOff = Color3.fromRGB(30, 30, 30),
    ElementBg = Color3.fromRGB(28, 28, 28),
    ElementHover = Color3.fromRGB(35, 35, 35),
    Accent = Color3.fromRGB(149, 95, 202),
    Text = Color3.fromRGB(240, 240, 240),
    TextDark = Color3.fromRGB(160, 160, 160),
    Stroke = Color3.fromRGB(45, 45, 45),
    SectionText = Color3.fromRGB(180, 180, 180)
}

local Tweens = {
    Fast = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    Medium = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
}

-- Setup Root GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "EliteLibraryGui"
ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.ResetOnSpawn = false

-- Notification Container
local NotifContainer = Instance.new("Frame")
NotifContainer.Name = "NotifContainer"
NotifContainer.Parent = ScreenGui
NotifContainer.BackgroundTransparency = 1
NotifContainer.Position = UDim2.new(1, -320, 1, -20)
NotifContainer.Size = UDim2.new(0, 300, 1, 0)
NotifContainer.AnchorPoint = Vector2.new(0, 1)

local NotifLayout = Instance.new("UIListLayout")
NotifLayout.Parent = NotifContainer
NotifLayout.SortOrder = Enum.SortOrder.LayoutOrder
NotifLayout.VerticalAlignment = Enum.VerticalAlignment.Bottom
NotifLayout.Padding = UDim.new(0, 10)

-- /// NOTIFICATION SYSTEM ///
function Library:Notify(title, text, duration)
    duration = duration or 3

    local NotifBg = Instance.new("Frame")
    NotifBg.Parent = NotifContainer
    NotifBg.BackgroundColor3 = Colors.Background
    NotifBg.Size = UDim2.new(1, 50, 0, 60) -- Start slightly offscreen
    NotifBg.BackgroundTransparency = 1

    local NotifCorner = Instance.new("UICorner")
    NotifCorner.CornerRadius = UDim.new(0, 6)
    NotifCorner.Parent = NotifBg

    local NotifStroke = Instance.new("UIStroke")
    NotifStroke.Parent = NotifBg
    NotifStroke.Color = Colors.Accent
    NotifStroke.Transparency = 1

    local TitleLbl = Instance.new("TextLabel")
    TitleLbl.Parent = NotifBg
    TitleLbl.BackgroundTransparency = 1
    TitleLbl.Position = UDim2.new(0, 10, 0, 5)
    TitleLbl.Size = UDim2.new(1, -20, 0, 20)
    TitleLbl.Font = Enum.Font.GothamBold
    TitleLbl.Text = title
    TitleLbl.TextColor3 = Colors.Text
    TitleLbl.TextSize = 14
    TitleLbl.TextXAlignment = Enum.TextXAlignment.Left
    TitleLbl.TextTransparency = 1

    local DescLbl = Instance.new("TextLabel")
    DescLbl.Parent = NotifBg
    DescLbl.BackgroundTransparency = 1
    DescLbl.Position = UDim2.new(0, 10, 0, 25)
    DescLbl.Size = UDim2.new(1, -20, 0, 25)
    DescLbl.Font = Enum.Font.Gotham
    DescLbl.Text = text
    DescLbl.TextColor3 = Colors.TextDark
    DescLbl.TextSize = 13
    DescLbl.TextXAlignment = Enum.TextXAlignment.Left
    DescLbl.TextWrapped = true
    DescLbl.TextTransparency = 1

    local TimerLine = Instance.new("Frame")
    TimerLine.Parent = NotifBg
    TimerLine.BackgroundColor3 = Colors.Accent
    TimerLine.Position = UDim2.new(0, 0, 1, -2)
    TimerLine.Size = UDim2.new(1, 0, 0, 2)
    TimerLine.BorderSizePixel = 0
    TimerLine.BackgroundTransparency = 1

    -- Animate In
    TweenService:Create(NotifBg, Tweens.Medium, {Size = UDim2.new(1, 0, 0, 60), BackgroundTransparency = 0}):Play()
    TweenService:Create(NotifStroke, Tweens.Medium, {Transparency = 0}):Play()
    TweenService:Create(TitleLbl, Tweens.Medium, {TextTransparency = 0}):Play()
    TweenService:Create(DescLbl, Tweens.Medium, {TextTransparency = 0}):Play()
    TweenService:Create(TimerLine, Tweens.Medium, {BackgroundTransparency = 0}):Play()

    -- Timer shrink
    TweenService:Create(TimerLine, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2)}):Play()

    task.delay(duration, function()
        -- Animate Out
        TweenService:Create(NotifBg, Tweens.Medium, {Size = UDim2.new(1, 50, 0, 60), BackgroundTransparency = 1}):Play()
        TweenService:Create(NotifStroke, Tweens.Medium, {Transparency = 1}):Play()
        TweenService:Create(TitleLbl, Tweens.Medium, {TextTransparency = 1}):Play()
        TweenService:Create(DescLbl, Tweens.Medium, {TextTransparency = 1}):Play()
        TweenService:Create(TimerLine, Tweens.Medium, {BackgroundTransparency = 1}):Play()
        
        task.wait(0.3)
        NotifBg:Destroy()
    end)
end

-- /// WATERMARK SYSTEM ///
function Library:CreateWatermark(text)
    local WatermarkBg = Instance.new("Frame")
    WatermarkBg.Name = "Watermark"
    WatermarkBg.Parent = ScreenGui
    WatermarkBg.BackgroundColor3 = Colors.Background
    WatermarkBg.Position = UDim2.new(0, 20, 0, 20)
    WatermarkBg.Size = UDim2.new(0, 250, 0, 30)

    local WMCorner = Instance.new("UICorner")
    WMCorner.CornerRadius = UDim.new(0, 6)
    WMCorner.Parent = WatermarkBg

    local WMStroke = Instance.new("UIStroke")
    WMStroke.Parent = WatermarkBg
    WMStroke.Color = Colors.Stroke

    local AccentLine = Instance.new("Frame")
    AccentLine.Parent = WatermarkBg
    AccentLine.BackgroundColor3 = Colors.Accent
    AccentLine.Size = UDim2.new(1, 0, 0, 2)
    AccentLine.BorderSizePixel = 0

    local WMLabel = Instance.new("TextLabel")
    WMLabel.Parent = WatermarkBg
    WMLabel.BackgroundTransparency = 1
    WMLabel.Position = UDim2.new(0, 10, 0, 0)
    WMLabel.Size = UDim2.new(1, -20, 1, 0)
    WMLabel.Font = Enum.Font.GothamSemibold
    WMLabel.Text = text .. " | FPS: -- | 00:00"
    WMLabel.TextColor3 = Colors.Text
    WMLabel.TextSize = 13
    WMLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- FPS & Time Loop
    local fps = 0
    RunService.RenderStepped:Connect(function(dt)
        fps = math.floor(1/dt)
    end)

    task.spawn(function()
        while task.wait(1) do
            local timeStr = os.date("%I:%M %p")
            WMLabel.Text = string.format("%s | FPS: %d | %s", text, fps, timeStr)
            
            -- Auto-scale width based on text bounds
            local bounds = WMLabel.TextBounds.X + 20
            TweenService:Create(WatermarkBg, Tweens.Fast, {Size = UDim2.new(0, bounds, 0, 30)}):Play()
        end
    end)
end

-- /// MAIN WINDOW ///
function Library:CreateWindow(titleText)
    local Window = {}
    
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Parent = ScreenGui
    MainFrame.BackgroundColor3 = Colors.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.Position = UDim2.new(0.5, -300, 0.5, -200)
    MainFrame.Size = UDim2.new(0, 600, 0, 400)
    MainFrame.ClipsDescendants = true
    
    -- Intro Animation
    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(MainFrame, Tweens.Medium, {Size = UDim2.new(0, 600, 0, 400)}):Play()
    
    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 8)
    MainCorner.Parent = MainFrame

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Parent = MainFrame
    MainStroke.Color = Colors.Stroke

    -- UI Toggle Logic (Right Control hides/shows UI)
    UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            MainFrame.Visible = not MainFrame.Visible
        end
    end)

    -- Dragging Logic
    local dragging, dragInput, dragStart, startPos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    -- Topbar
    local Topbar = Instance.new("Frame")
    Topbar.Parent = MainFrame
    Topbar.BackgroundColor3 = Colors.Topbar
    Topbar.Size = UDim2.new(1, 0, 0, 40)
    
    local TopbarCorner = Instance.new("UICorner")
    TopbarCorner.CornerRadius = UDim.new(0, 8)
    TopbarCorner.Parent = Topbar
    
    local TopbarBottomFix = Instance.new("Frame")
    TopbarBottomFix.Parent = Topbar
    TopbarBottomFix.BackgroundColor3 = Colors.Topbar
    TopbarBottomFix.BorderSizePixel = 0
    TopbarBottomFix.Position = UDim2.new(0, 0, 1, -5)
    TopbarBottomFix.Size = UDim2.new(1, 0, 0, 5)

    local TopbarStroke = Instance.new("Frame")
    TopbarStroke.Parent = Topbar
    TopbarStroke.BackgroundColor3 = Colors.Accent
    TopbarStroke.BorderSizePixel = 0
    TopbarStroke.Position = UDim2.new(0, 0, 1, 0)
    TopbarStroke.Size = UDim2.new(1, 0, 0, 2)

    local Title = Instance.new("TextLabel")
    Title.Parent = Topbar
    Title.BackgroundTransparency = 1
    Title.Position = UDim2.new(0, 15, 0, 0)
    Title.Size = UDim2.new(0, 200, 1, 0)
    Title.Font = Enum.Font.GothamBold
    Title.Text = titleText or "Script Hub"
    Title.TextColor3 = Colors.Text
    Title.TextSize = 16
    Title.TextXAlignment = Enum.TextXAlignment.Left

    -- Tabs Container
    local TabContainer = Instance.new("Frame")
    TabContainer.Parent = MainFrame
    TabContainer.BackgroundTransparency = 1
    TabContainer.Position = UDim2.new(0, 10, 0, 52)
    TabContainer.Size = UDim2.new(0, 140, 1, -62)

    local TabList = Instance.new("UIListLayout")
    TabList.Parent = TabContainer
    TabList.SortOrder = Enum.SortOrder.LayoutOrder
    TabList.Padding = UDim.new(0, 6)

    local PageContainer = Instance.new("Frame")
    PageContainer.Parent = MainFrame
    PageContainer.BackgroundTransparency = 1
    PageContainer.Position = UDim2.new(0, 160, 0, 52)
    PageContainer.Size = UDim2.new(1, -170, 1, -62)

    local CurrentTab = nil

    function Window:CreateTab(tabName)
        local Tab = {}
        
        local TabButton = Instance.new("TextButton")
        TabButton.Parent = TabContainer
        TabButton.BackgroundColor3 = Colors.TabOff
        TabButton.Size = UDim2.new(1, 0, 0, 32)
        TabButton.Font = Enum.Font.GothamSemibold
        TabButton.Text = tabName
        TabButton.TextColor3 = Colors.TextDark
        TabButton.TextSize = 14
        TabButton.AutoButtonColor = false

        local TabCorner = Instance.new("UICorner")
        TabCorner.CornerRadius = UDim.new(0, 6)
        TabCorner.Parent = TabButton

        local TabStroke = Instance.new("UIStroke")
        TabStroke.Parent = TabButton
        TabStroke.Color = Colors.Stroke

        local Page = Instance.new("ScrollingFrame")
        Page.Parent = PageContainer
        Page.Active = true
        Page.BackgroundTransparency = 1
        Page.BorderSizePixel = 0
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.ScrollBarThickness = 2
        Page.ScrollBarImageColor3 = Colors.Accent
        Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        Page.Visible = false

        local PageList = Instance.new("UIListLayout")
        PageList.Parent = Page
        PageList.SortOrder = Enum.SortOrder.LayoutOrder
        PageList.Padding = UDim.new(0, 8)

        local PagePadding = Instance.new("UIPadding")
        PagePadding.Parent = Page
        PagePadding.PaddingTop = UDim.new(0, 2)
        PagePadding.PaddingLeft = UDim.new(0, 2)
        PagePadding.PaddingRight = UDim.new(0, 10)
        PagePadding.PaddingBottom = UDim.new(0, 10)

        if CurrentTab == nil then
            CurrentTab = TabButton
            Page.Visible = true
            TabButton.BackgroundColor3 = Colors.Accent
            TabButton.TextColor3 = Colors.Text
            TabStroke.Color = Colors.Accent
        end

        TabButton.MouseButton1Click:Connect(function()
            if CurrentTab == TabButton then return end
            
            for _, v in pairs(TabContainer:GetChildren()) do
                if v:IsA("TextButton") then
                    TweenService:Create(v, Tweens.Fast, {BackgroundColor3 = Colors.TabOff, TextColor3 = Colors.TextDark}):Play()
                    v.UIStroke.Color = Colors.Stroke
                end
            end
            for _, v in pairs(PageContainer:GetChildren()) do
                if v:IsA("ScrollingFrame") then v.Visible = false end
            end

            CurrentTab = TabButton
            Page.Visible = true
            TabStroke.Color = Colors.Accent
            TweenService:Create(TabButton, Tweens.Fast, {BackgroundColor3 = Colors.Accent, TextColor3 = Colors.Text}):Play()
            
            Page.Position = UDim2.new(0, 10, 0, 0)
            TweenService:Create(Page, Tweens.Medium, {Position = UDim2.new(0, 0, 0, 0)}):Play()
        end)

        function Tab:CreateSection(text)
            local SectionLabel = Instance.new("TextLabel")
            SectionLabel.Parent = Page
            SectionLabel.BackgroundTransparency = 1
            SectionLabel.Size = UDim2.new(1, 0, 0, 25)
            SectionLabel.Font = Enum.Font.GothamBold
            SectionLabel.Text = "  " .. text
            SectionLabel.TextColor3 = Colors.SectionText
            SectionLabel.TextSize = 12
            SectionLabel.TextXAlignment = Enum.TextXAlignment.Left

            local Line = Instance.new("Frame")
            Line.Parent = SectionLabel
            Line.BackgroundColor3 = Colors.Stroke
            Line.BorderSizePixel = 0
            Line.Position = UDim2.new(0, 0, 1, -5)
            Line.Size = UDim2.new(1, 0, 0, 1)
        end

        function Tab:CreateButton(text, callback)
            local Button = Instance.new("TextButton")
            Button.Parent = Page
            Button.BackgroundColor3 = Colors.ElementBg
            Button.Size = UDim2.new(1, 0, 0, 38)
            Button.Font = Enum.Font.GothamSemibold
            Button.Text = text
            Button.TextColor3 = Colors.Text
            Button.TextSize = 14
            Button.AutoButtonColor = false

            local BtnCorner = Instance.new("UICorner")
            BtnCorner.CornerRadius = UDim.new(0, 6)
            BtnCorner.Parent = Button
            local BtnStroke = Instance.new("UIStroke")
            BtnStroke.Parent = Button
            BtnStroke.Color = Colors.Stroke

            Button.MouseEnter:Connect(function() TweenService:Create(Button, Tweens.Fast, {BackgroundColor3 = Colors.ElementHover}):Play() end)
            Button.MouseLeave:Connect(function() TweenService:Create(Button, Tweens.Fast, {BackgroundColor3 = Colors.ElementBg}):Play() end)
            Button.MouseButton1Down:Connect(function() TweenService:Create(Button, Tweens.Fast, {Size = UDim2.new(0.98, 0, 0, 36)}):Play() BtnStroke.Color = Colors.Accent end)
            Button.MouseButton1Up:Connect(function() TweenService:Create(Button, Tweens.Fast, {Size = UDim2.new(1, 0, 0, 38)}):Play() BtnStroke.Color = Colors.Stroke pcall(callback) end)
        end

        function Tab:CreateToggle(text, callback)
            local toggled = false
            local ToggleBtn = Instance.new("TextButton")
            ToggleBtn.Parent = Page
            ToggleBtn.BackgroundColor3 = Colors.ElementBg
            ToggleBtn.Size = UDim2.new(1, 0, 0, 38)
            ToggleBtn.Text = ""
            ToggleBtn.AutoButtonColor = false

            local TogCorner = Instance.new("UICorner")
            TogCorner.CornerRadius = UDim.new(0, 6)
            TogCorner.Parent = ToggleBtn
            local TogStroke = Instance.new("UIStroke")
            TogStroke.Parent = ToggleBtn
            TogStroke.Color = Colors.Stroke

            local Label = Instance.new("TextLabel")
            Label.Parent = ToggleBtn
            Label.BackgroundTransparency = 1
            Label.Position = UDim2.new(0, 15, 0, 0)
            Label.Size = UDim2.new(1, -60, 1, 0)
            Label.Font = Enum.Font.GothamSemibold
            Label.Text = text
            Label.TextColor3 = Colors.Text
            Label.TextSize = 14
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local SwitchBg = Instance.new("Frame")
            SwitchBg.Parent = ToggleBtn
            SwitchBg.BackgroundColor3 = Colors.TabOff
            SwitchBg.Position = UDim2.new(1, -45, 0.5, -10)
            SwitchBg.Size = UDim2.new(0, 34, 0, 20)
            local SwitchCorner = Instance.new("UICorner")
            SwitchCorner.CornerRadius = UDim.new(1, 0)
            SwitchCorner.Parent = SwitchBg

            local Indicator = Instance.new("Frame")
            Indicator.Parent = SwitchBg
            Indicator.BackgroundColor3 = Colors.TextDark
            Indicator.Position = UDim2.new(0, 2, 0.5, -8)
            Indicator.Size = UDim2.new(0, 16, 0, 16)
            local IndCorner = Instance.new("UICorner")
            IndCorner.CornerRadius = UDim.new(1, 0)
            IndCorner.Parent = Indicator

            ToggleBtn.MouseEnter:Connect(function() TweenService:Create(ToggleBtn, Tweens.Fast, {BackgroundColor3 = Colors.ElementHover}):Play() end)
            ToggleBtn.MouseLeave:Connect(function() TweenService:Create(ToggleBtn, Tweens.Fast, {BackgroundColor3 = Colors.ElementBg}):Play() end)

            ToggleBtn.MouseButton1Click:Connect(function()
                toggled = not toggled
                local goalPos = toggled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
                TweenService:Create(Indicator, Tweens.Fast, {Position = goalPos, BackgroundColor3 = toggled and Color3.fromRGB(255,255,255) or Colors.TextDark}):Play()
                TweenService:Create(SwitchBg, Tweens.Fast, {BackgroundColor3 = toggled and Colors.Accent or Colors.TabOff}):Play()
                pcall(callback, toggled)
            end)
        end

        function Tab:CreateSlider(text, min, max, default, callback)
            default = default or min
            local SliderBg = Instance.new("Frame")
            SliderBg.Parent = Page
            SliderBg.BackgroundColor3 = Colors.ElementBg
            SliderBg.Size = UDim2.new(1, 0, 0, 55)

            local SliderCorner = Instance.new("UICorner")
            SliderCorner.CornerRadius = UDim.new(0, 6)
            SliderCorner.Parent = SliderBg
            local SliderStroke = Instance.new("UIStroke")
            SliderStroke.Parent = SliderBg
            SliderStroke.Color = Colors.Stroke

            local TitleLabel = Instance.new("TextLabel")
            TitleLabel.Parent = SliderBg
            TitleLabel.BackgroundTransparency = 1
            TitleLabel.Position = UDim2.new(0, 15, 0, 5)
            TitleLabel.Size = UDim2.new(0.5, 0, 0, 25)
            TitleLabel.Font = Enum.Font.GothamSemibold
            TitleLabel.Text = text
            TitleLabel.TextColor3 = Colors.Text
            TitleLabel.TextSize = 14
            TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

            local ValueLabel = Instance.new("TextLabel")
            ValueLabel.Parent = SliderBg
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.Position = UDim2.new(0.5, -15, 0, 5)
            ValueLabel.Size = UDim2.new(0.5, 0, 0, 25)
            ValueLabel.Font = Enum.Font.Gotham
            ValueLabel.Text = tostring(default)
            ValueLabel.TextColor3 = Colors.Accent
            ValueLabel.TextSize = 14
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right

            local Track = Instance.new("Frame")
            Track.Parent = SliderBg
            Track.BackgroundColor3 = Colors.TabOff
            Track.Position = UDim2.new(0, 15, 0, 35)
            Track.Size = UDim2.new(1, -30, 0, 6)
            local TrackCorner = Instance.new("UICorner")
            TrackCorner.CornerRadius = UDim.new(1, 0)
            TrackCorner.Parent = Track

            local Fill = Instance.new("Frame")
            Fill.Parent = Track
            Fill.BackgroundColor3 = Colors.Accent
            Fill.Size = UDim2.new(math.clamp((default - min) / (max - min), 0, 1), 0, 1, 0)
            local FillCorner = Instance.new("UICorner")
            FillCorner.CornerRadius = UDim.new(1, 0)
            FillCorner.Parent = Fill

            local dragging = false
            local function updateSlider(input)
                local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                local value = math.floor(min + ((max - min) * pos))
                TweenService:Create(Fill, Tweens.Fast, {Size = UDim2.new(pos, 0, 1, 0)}):Play()
                ValueLabel.Text = tostring(value)
                pcall(callback, value)
            end

            SliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true updateSlider(input) end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(input) end
            end)
        end

        function Tab:CreateKeybind(text, defaultKey, callback)
            local currentKey = defaultKey
            local isBinding = false
            
            local BindBtn = Instance.new("TextButton")
            BindBtn.Parent = Page
            BindBtn.BackgroundColor3 = Colors.ElementBg
            BindBtn.Size = UDim2.new(1, 0, 0, 38)
            BindBtn.Text = ""
            BindBtn.AutoButtonColor = false

            local BindCorner = Instance.new("UICorner")
            BindCorner.CornerRadius = UDim.new(0, 6)
            BindCorner.Parent = BindBtn
            local BindStroke = Instance.new("UIStroke")
            BindStroke.Parent = BindBtn
            BindStroke.Color = Colors.Stroke

            local Label = Instance.new("TextLabel")
            Label.Parent = BindBtn
            Label.BackgroundTransparency = 1
            Label.Position = UDim2.new(0, 15, 0, 0)
            Label.Size = UDim2.new(0.5, 0, 1, 0)
            Label.Font = Enum.Font.GothamSemibold
            Label.Text = text
            Label.TextColor3 = Colors.Text
            Label.TextSize = 14
            Label.TextXAlignment = Enum.TextXAlignment.Left

            local KeyDisplay = Instance.new("TextLabel")
            KeyDisplay.Parent = BindBtn
            KeyDisplay.BackgroundTransparency = 1
            KeyDisplay.Position = UDim2.new(0.5, -15, 0, 0)
            KeyDisplay.Size = UDim2.new(0.5, 0, 1, 0)
            KeyDisplay.Font = Enum.Font.GothamBold
            KeyDisplay.Text = "[" .. currentKey.Name .. "]"
            KeyDisplay.TextColor3 = Colors.Accent
            KeyDisplay.TextSize = 14
            KeyDisplay.TextXAlignment = Enum.TextXAlignment.Right

            BindBtn.MouseButton1Click:Connect(function()
                isBinding = true
                KeyDisplay.Text = "[...]"
                KeyDisplay.TextColor3 = Colors.TextDark
            end)

            UserInputService.InputBegan:Connect(function(input, gpe)
                if isBinding and input.UserInputType == Enum.UserInputType.Keyboard then
                    currentKey = input.KeyCode
                    KeyDisplay.Text = "[" .. currentKey.Name .. "]"
                    KeyDisplay.TextColor3 = Colors.Accent
                    isBinding = false
                elseif not isBinding and input.KeyCode == currentKey and not gpe then
                    pcall(callback)
                end
            end)
        end

        return Tab
    end

    return Window
end

return Library
